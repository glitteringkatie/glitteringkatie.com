---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import PostPreview from '../components/PostPreview.astro';
import HomeContent from '../components/HomeContent';
import { getExcerpt } from '../utils/excerpt';

const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => b.data.date.localeCompare(a.data.date))
  .slice(0, 3)
  .map(post => ({
    slug: post.slug,
    title: post.data.title,
    coverImage: post.data.coverImage,
    altText: post.data.altText,
    excerpt: getExcerpt(post.body),
  }));
---
<BaseLayout page="home">
  <Container>
    <HomeContent client:load />

    <div class="flex flex-col justify-center items-center pt-16 pb-20">
      <h2 class="text-center uppercase font-light text-3xl tracking-widest pb-4">My Latest Posts</h2>
      <div class="md:grid grid-cols-3 gap-x-8 items-top mx-auto py-4">
        {latestPosts.map(post => (
          <PostPreview
            slug={post.slug}
            title={post.title}
            coverImage={post.coverImage}
            altText={post.altText}
            excerpt={post.excerpt}
          />
        ))}
      </div>
      <a
        href="/posts"
        class="bg-pine text-cream pt-4 px-6 pb-3 rounded-full text-xl font-serif font-semibold lowercase">
        browse all posts
      </a>
    </div>
  </Container>
</BaseLayout>
